AOMS_SQLITE_DB_PATH=./data/aoms.db

# Telegram — заполнить после создания бота через @BotFather (см. README)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_GROUP_CHAT_ID=
TELEGRAM_TECHNICIAN_CHAT_ID=
TELEGRAM_MANAGER_CHAT_ID=
# Отдельная группа именно для проблемных/неисправных банкоматов (не общая
# группа отчётов об очистке). Пример: -5246695690
TELEGRAM_PROBLEM_ATMS_CHAT_ID=

# Яндекс Маршрутизация (VRP) — оптимизация порядка объезда точек.
# Отдельная регистрация на yandex.ru/routing/vrp/, не обычный Maps API-ключ.
# Если не задано — маршрут строится в обычном порядке, без оптимизации.
YANDEX_ROUTING_API_KEY=

# Публичный адрес приложения на Railway (для кнопки запуска Mini App).
# Например: https://aoms-web-production.up.railway.app
APP_PUBLIC_URL=

# Архивный канал для хранения фото (вместо диска Railway). Бот должен
# быть добавлен в канал как администратор. Узнать ID канала: добавьте
# бота в канал, отправьте туда любое сообщение, вызовите
# getUpdates и посмотрите chat.id (обычно вида -100XXXXXXXXXX).
TELEGRAM_ARCHIVE_CHANNEL_ID=

# Простой пароль для входа в веб-интерфейс руководителя (не влияет на
# Mini App сотрудников — у неё свой вход через Telegram). Если не
# задан — вход отключён, веб-интерфейс открыт без пароля как раньше.
ADMIN_PASSWORD=
